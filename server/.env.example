MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=whitebox
MQTT_PASSWORD=
TOPIC_PREFIX=whitebox
PORT=8080
HOOK_HTTP_TOKEN=
HOOK_STATE_STALE_SECONDS=1800

# TTS 语音设置
TTS_ENABLED=true
TTS_ORCHESTRATOR=server
# local_indextts / cloud_openai_compatible / doubao / mock / mqtt_indextts
TTS_PROVIDER=local_indextts
TTS_VOICE=
TTS_SAMPLE_RATE=24000
TTS_MAX_TEXT_CHARS=120
TTS_MIN_TEXT_CHARS=6
TTS_HTTP_TIMEOUT=30
TTS_PUBLIC_BASE_URL=

# 本地 IndexTTS (IndexTTS2 异步 API)
TTS_LOCAL_BASE_URL=http://127.0.0.1:9877
TTS_LOCAL_PATH=/tts
TTS_LOCAL_VOICE=test_voice.wav

# TTS 代理（server 无法直连本地局域网时，通过 cc-dashboard 代理）
# 留空 = 直连 IndexTTS2；填 cc-dashboard 的公网地址 = 走代理
TTS_PROXY_URL=

# 云端 OpenAI 兼容
TTS_CLOUD_BASE_URL=https://api.openai.com
TTS_CLOUD_PATH=/v1/audio/speech
TTS_CLOUD_MODEL=tts-1
TTS_API_KEY=
TTS_CLOUD_VOICE=alloy
TTS_CLOUD_RESPONSE_FORMAT=mp3
TTS_CLOUD_SPEED=1.0

# 豆包 TTS
DOUBAO_API_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
DOUBAO_SPEAKER=zh_female_xiaohe_uranus_bigtts
DOUBAO_RESOURCE_ID=
DOUBAO_SPEECH_RATE=0
DOUBAO_LOUDNESS_RATE=0
DOUBAO_PITCH=0
DOUBAO_EMOTION=
DOUBAO_EMOTION_SCALE=0

# 小米 MiMo TTS
MIMO_BASE_URL=https://api.xiaomimimo.com
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-tts
MIMO_VOICE=

# Mock 测试
TTS_MOCK_AUDIO_PATH=
