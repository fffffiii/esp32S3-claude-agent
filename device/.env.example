MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=whitebox
MQTT_PASSWORD=
TOPIC_PREFIX=whitebox
STATUS_SOURCE=hooks
DASHBOARD_HOOK_URL=http://127.0.0.1:5000/api/hook/state
HOOK_HTTP_TOKEN=
HOOK_HTTP_TIMEOUT=0.5

# 云端服务同步地址，未启用可留空
CLOUD_HOOK_URL=http://your-server-host:8080/api/hook/state?forward=1
CLOUD_HOOK_TOKEN=

# TTS 语音设置
TTS_ENABLED=true
TTS_ORCHESTRATOR=local
TTS_PROVIDER=local_indextts
TTS_LOCAL_BASE_URL=http://127.0.0.1:9877
TTS_LOCAL_VOICE=test_voice.wav

# 小米 MiMo TTS
MIMO_BASE_URL=https://api.xiaomimimo.com
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-tts
MIMO_VOICE=
