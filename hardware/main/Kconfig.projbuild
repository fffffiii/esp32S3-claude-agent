menu "Example Configuration"

config WIFI_SSID
    string "WiFi SSID"
	default "myssid"
	help
		SSID (network name) for the example to connect to.

config WIFI_PASSWORD
    string "WiFi Password"
	default "myssid"
	help
		WiFi password (WPA or WPA2) for the example to use.

		Can be left blank if the network has no security set.

config SERVER_URI
    string "Server URL to send data"
    default "http://server-host:8000/upload"
    help
        Server URL to send data

config MQTT_HOST
    string "MQTT Broker Host"
    default "broker.example.com"
    help
        MQTT broker IP address or hostname.

config MQTT_PORT
    int "MQTT Broker Port"
    default 1883
    help
        MQTT broker port number.

config MQTT_USERNAME
    string "MQTT Username"
    default "whitebox"
    help
        MQTT broker login username.

config MQTT_PASSWORD
    string "MQTT Password"
    default "change_me"
    help
        MQTT broker login password.
endmenu
